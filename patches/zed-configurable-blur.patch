@@ -2378,6 +2378,14 @@ impl Window {
             .set_background_appearance(background_appearance);
     }
 
+    /// Nice patch (configurable-blur): set the numeric background blur radius
+    /// applied when the appearance is `Blurred`. On macOS this routes through
+    /// the WindowServer's `CGSSetWindowBackgroundBlurRadius` on all versions;
+    /// on other backends it is a no-op. A radius of 0 disables the blur.
+    pub fn set_background_blur_radius(&self, radius: u32) {
+        self.platform_window.set_background_blur_radius(radius);
+    }
+
     /// Mark the window as dirty at the platform level.
     pub fn set_window_edited(&mut self, edited: bool) {
         self.platform_window.set_edited(edited);
