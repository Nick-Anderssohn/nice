+// Nice patch (display-link self-heal): how long to wait before re-checking a
+// display link that failed to (re)start. Long enough to outlast a transient
+// occlusion-state/display-reconfiguration hiccup, short enough that a healed
+// window resumes presenting before a user reads it as frozen.
+const DISPLAY_LINK_RETRY_DELAY: Duration = Duration::from_millis(50);
+
+/// Nice patch (display-link self-heal): the delayed re-check queued by
+/// `MacWindowState::schedule_display_link_retry`. Runs on the main thread
+/// (spawned on the window's `ForegroundExecutor`, mirroring `synthetic_drag`;
+/// only the timer awaits on the background executor). No-ops when the window
+/// is gone/closed, when a link is already running (an occlusion / key-status /
+/// `displayLayer:` edge beat us to the restart), or when the window is
+/// genuinely not occlusion-visible (the occlusion handler owns the
+/// visible-edge restart). What remains is exactly the wedge state — a VISIBLE
+/// window with a stopped display link, which nothing else will ever heal — so
+/// log it (making field wedges visible) and re-run `start_display_link`. A
+/// repeat failure re-schedules through the same single-flight guard, so a
+/// persistent fault retries at ~20 Hz instead of freezing presentation
+/// forever.
+async fn retry_start_display_link(
+    window_state: Weak<Mutex<MacWindowState>>,
+    executor: BackgroundExecutor,
+) {
+    executor.timer(DISPLAY_LINK_RETRY_DELAY).await;
+    let Some(window_state) = window_state.upgrade() else {
+        return;
+    };
+    let mut lock = window_state.lock();
+    lock.display_link_retry_pending = false;
+    if lock.closed.load(Ordering::Acquire) || lock.display_link.is_some() {
+        return;
+    }
+    let visible = unsafe {
+        lock.native_window
+            .occlusionState()
+            .contains(NSWindowOcclusionState::NSWindowOcclusionStateVisible)
+    };
+    if !visible {
+        return;
+    }
+    log::warn!("display link stopped on a visible window; restarting it (self-heal)");
+    lock.start_display_link();
+}
