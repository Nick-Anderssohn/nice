--- a/crates/gpui_macos/src/shaders.metal
+++ b/crates/gpui_macos/src/shaders.metal
@@
+// Kitty text_composition_strategy "1.7 30" (SwiftTerm .appleApprox).
+// Spike: baked constants; product lane may hoist these into a uniform.
+constant float TEXT_COMPOSITION_GAMMA_INV = 1.0 / 1.7;
+constant float TEXT_COMPOSITION_CONTRAST = 1.30;
+
 struct MonochromeSpriteVertexOutput {
   float4 position [[position]];
   float2 tile_position;
   float4 color [[flat]];
+  float mix_factor [[flat]];
   float4 clip_distance;
 };

 struct MonochromeSpriteFragmentInput {
   float4 position [[position]];
   float2 tile_position;
   float4 color [[flat]];
+  float mix_factor [[flat]];
   float4 clip_distance;
 };

@@ vertex MonochromeSpriteVertexOutput monochrome_sprite_vertex(...)
   float2 tile_position = to_tile_position(unit_vertex, sprite.tile, atlas_size);
   float4 color = hsla_to_rgba(sprite.color);
+  // mixFactor = clamp((1 - L_fg + L_bg) * 0.5, 0, 1); negative bg_luminance
+  // disables the curve (sentinel -1 propagated to the fragment stage).
+  float mix_factor = -1.0;
+  if (sprite.bg_luminance >= 0.0) {
+    float fg_luminance =
+        dot(color.rgb, float3(0.2126, 0.7152, 0.0722));
+    mix_factor =
+        clamp((1.0 - fg_luminance + sprite.bg_luminance) * 0.5, 0.0, 1.0);
+  }
   return MonochromeSpriteVertexOutput{
       device_position,
       tile_position,
       color,
+      mix_factor,
       {clip_distance.x, clip_distance.y, clip_distance.z, clip_distance.w}};
 }

@@ fragment float4 monochrome_sprite_fragment(...)
   float4 sample =
       atlas_texture.sample(atlas_texture_sampler, input.tile_position);
   float4 color = input.color;
-  color.a *= sample.a;
+  float coverage = sample.a;
+  if (input.mix_factor >= 0.0) {
+    // clamp(mix(cov, pow(cov, 1/gamma), mixFactor) * contrast, 0, 1) —
+    // SwiftTerm Shaders.metal:terminal_text_fragment_gray, applied to the
+    // straight-alpha coverage instead of premultiplying (same math over
+    // GPUI's SourceAlpha/OneMinusSourceAlpha blend).
+    float curved = mix(coverage, pow(coverage, TEXT_COMPOSITION_GAMMA_INV),
+                       input.mix_factor);
+    coverage = clamp(curved * TEXT_COMPOSITION_CONTRAST, 0.0, 1.0);
+  }
+  color.a *= coverage;
   return color;

