+//! NICE PHASE-0 PATCH — process-wide spike metrics for the Nice rewrite
+//! Phase-0 program (spikes/phase0-poc; see its README §"Vendored gpui").
+//!
+//! Everything here is passive bookkeeping read by the spike bins through
+//! `gpui::nice_poc_metrics::…` (the crate is path-patched, so the module is
+//! directly importable). Nothing in this module changes rendering behavior;
+//! the only optional behavior switch (`NICE_POC_GPU_TS`) adds a read of the
+//! command buffer's GPU timestamps inside the *already existing* completed
+//! handler.
+//!
+//! Recorders wired by the patch:
+//!  * `DRAW_DUR_NS` — CPU wall duration of every `MetalRenderer::draw`
+//!    (drawable acquire -> encode -> commit [-> waitUntilScheduled ->
+//!    present]) pushed by the `DrawSignpost` guard's Drop (spike 6: per-draw
+//!    CPU cost — the number comparable to Nice's `Metal.Draw` 1.2 ms p50).
+//!  * `GPU_DUR_NS` — `GPUEndTime - GPUStartTime` of each command buffer,
+//!    read in the completed handler ONLY when env `NICE_POC_GPU_TS=1`
+//!    (spike 6: GPU-side per-frame cost).
+//!  * `SHAPE_*` — LineLayoutCache::layout_line outcome counters (spike 6:
+//!    shape-cache hit rate; current-frame hit / previous-frame hit / miss =
+//!    fresh CoreText shape).
+//!  * `ATLAS_MONO` / `ATLAS_POLY` — MetalAtlas texture/tile/upload counters
+//!    (spike 10: atlas pressure; what `remove()` actually reclaims).
+
+use std::sync::Mutex;
+use std::sync::OnceLock;
+use std::sync::atomic::{AtomicU64, Ordering};
+
+/// Safety cap so an unattended run cannot grow the duration vectors
+/// unboundedly (1M samples = 8 MB; a 60 Hz run emits ~216k/h).
+const DUR_CAP: usize = 1 << 20;
+
+/// Per-draw CPU durations (ns) of `MetalRenderer::draw`, in call order,
+/// across ALL windows (draws are serialized on the main thread).
+pub static DRAW_DUR_NS: Mutex<Vec<u64>> = Mutex::new(Vec::new());
+
+/// Per-command-buffer GPU durations (ns), recorded by the completed handler
+/// when `NICE_POC_GPU_TS=1`. Completion order (still monotone per buffer).
+pub static GPU_DUR_NS: Mutex<Vec<u64>> = Mutex::new(Vec::new());
+
+/// Record one `MetalRenderer::draw` CPU duration (called by the Draw guard).
+pub fn record_draw_dur_ns(ns: u64) {
+    let mut v = DRAW_DUR_NS.lock().unwrap();
+    if v.len() < DUR_CAP {
+        v.push(ns);
+    }
+}
+
+/// Record one command buffer's GPU execution duration (completed handler).
+pub fn record_gpu_dur_ns(ns: u64) {
+    let mut v = GPU_DUR_NS.lock().unwrap();
+    if v.len() < DUR_CAP {
+        v.push(ns);
+    }
+}
+
+/// True iff env `NICE_POC_GPU_TS` is "1" | "true" (read once). Gates the
+/// GPUStartTime/GPUEndTime read in the metal_renderer completed handler.
+pub fn gpu_ts_enabled() -> bool {
+    static V: OnceLock<bool> = OnceLock::new();
+    *V.get_or_init(|| {
+        matches!(
+            std::env::var("NICE_POC_GPU_TS").as_deref(),
+            Ok("1") | Ok("true")
+        )
+    })
+}
+
+// ---------------------------------------------------------------------------
+// Shape cache (LineLayoutCache::layout_line) outcome counters — spike 6.
+// ---------------------------------------------------------------------------
+
+/// Hit in the CURRENT frame's cache (same line shaped again this frame).
+pub static SHAPE_HIT_CURRENT: AtomicU64 = AtomicU64::new(0);
+/// Hit carried over from the PREVIOUS frame (unchanged line across frames).
+pub static SHAPE_HIT_PREVIOUS: AtomicU64 = AtomicU64::new(0);
+/// Miss — a fresh platform (CoreText) shaping call.
+pub static SHAPE_MISS: AtomicU64 = AtomicU64::new(0);
+
+/// (hit_current, hit_previous, miss) snapshot.
+pub fn shape_cache_stats() -> (u64, u64, u64) {
+    (
+        SHAPE_HIT_CURRENT.load(Ordering::Relaxed),
+        SHAPE_HIT_PREVIOUS.load(Ordering::Relaxed),
+        SHAPE_MISS.load(Ordering::Relaxed),
+    )
+}
+
+// ---------------------------------------------------------------------------
+// Atlas counters — spike 10. One bank per texture kind, cumulative over the
+// process lifetime and across every window's atlas (aggregate).
+// ---------------------------------------------------------------------------
+
+/// Cumulative counters for one atlas texture kind (monochrome/polychrome).
+pub struct AtlasBank {
+    /// Atlas textures created (each is a real MTLTexture allocation).
+    pub tex_allocated: AtomicU64,
+    /// Atlas textures actually FREED (storage reclaimed): gpui 0.2.2 frees a
+    /// texture only when its live-tile refcount reaches zero — individual
+    /// tile rectangles are never returned to the allocator.
+    pub tex_freed: AtomicU64,
+    /// Bytes of texture storage allocated (w*h*bytes-per-pixel).
+    pub tex_bytes_allocated: AtomicU64,
+    /// Bytes of texture storage freed (whole-texture reclaim only).
+    pub tex_bytes_freed: AtomicU64,
+    /// Tiles inserted (`get_or_insert_with` build path).
+    pub tiles_inserted: AtomicU64,
+    /// Tiles removed (`remove`; storage is NOT reclaimed per tile).
+    pub tiles_removed: AtomicU64,
+    /// Bytes uploaded through `replace_region` (tile upload traffic).
+    pub upload_bytes: AtomicU64,
+}
+
+impl AtlasBank {
+    const fn new() -> Self {
+        AtlasBank {
+            tex_allocated: AtomicU64::new(0),
+            tex_freed: AtomicU64::new(0),
+            tex_bytes_allocated: AtomicU64::new(0),
+            tex_bytes_freed: AtomicU64::new(0),
+            tiles_inserted: AtomicU64::new(0),
+            tiles_removed: AtomicU64::new(0),
+            upload_bytes: AtomicU64::new(0),
+        }
+    }
+
+    /// Plain-u64 snapshot: (tex_alloc, tex_freed, bytes_alloc, bytes_freed,
+    /// tiles_inserted, tiles_removed, upload_bytes).
+    pub fn snapshot(&self) -> [u64; 7] {
+        [
+            self.tex_allocated.load(Ordering::Relaxed),
+            self.tex_freed.load(Ordering::Relaxed),
+            self.tex_bytes_allocated.load(Ordering::Relaxed),
+            self.tex_bytes_freed.load(Ordering::Relaxed),
+            self.tiles_inserted.load(Ordering::Relaxed),
+            self.tiles_removed.load(Ordering::Relaxed),
+            self.upload_bytes.load(Ordering::Relaxed),
+        ]
+    }
+}
+
+/// Monochrome atlas (A8 — glyph masks).
+pub static ATLAS_MONO: AtlasBank = AtlasBank::new();
+/// Polychrome atlas (BGRA8 — images/emoji/`paint_image`).
+pub static ATLAS_POLY: AtlasBank = AtlasBank::new();
