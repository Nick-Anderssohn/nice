+// ===========================================================================
+// NICE PHASE-0 PATCH — spike instrumentation for the Nice rewrite Phase-0
+// program (spikes/phase0-poc; see its README §"Vendored gpui"). Two pieces,
+// both inert by default:
+//
+//  1. `forced_txn()` — env `NICE_POC_GPUI_TXN=1` (also accepts "true"/"txn")
+//     forces GPUI's own Metal present into `presents_with_transaction` mode
+//     for the entire run (§13 spike 3: does Path A's 31 ms tail collapse when
+//     the GPUI side ALSO co-commits with the CA transaction?). gpui 0.2.2
+//     already ships the machinery (metal_renderer.rs draw(); window.rs
+//     display_layer/windowDidBecomeKey toggle it transiently); this override
+//     simply pins it on. Env unset => byte-identical stock behavior.
+//
+//  2. `DrawSignpost` — an os_signpost interval named "Draw" on subsystem
+//     "dev.nickanderssohn.gpui-term", category "present", spanning
+//     `MetalRenderer::draw` (drawable acquire -> encode -> commit ->
+//     [present when transactional]). Emitted via a tiny C shim
+//     (src/platform/mac/nice_signpost.c, compiled by this crate's build.rs)
+//     that uses the real <os/signpost.h> macros, so `xctrace record
+//     --template Logging` sees it exactly like SwiftTerm's `Metal.Draw`
+//     (subsystem org.tirania.SwiftTerm, category MetalProfile). Zero-cost
+//     when no recorder is attached (os_signpost_enabled gate).
+// ===========================================================================
+mod nice_poc {
+    use std::sync::OnceLock;
+
+    /// True iff env `NICE_POC_GPUI_TXN` is "1" | "true" | "txn" (read once).
+    pub(super) fn forced_txn() -> bool {
+        static FORCED: OnceLock<bool> = OnceLock::new();
+        *FORCED.get_or_init(|| {
+            matches!(
+                std::env::var("NICE_POC_GPUI_TXN").as_deref(),
+                Ok("1") | Ok("true") | Ok("txn")
+            )
+        })
+    }
+
+    unsafe extern "C" {
+        /// Returns a live os_signpost interval id (0 when not recording).
+        fn nice_signpost_draw_begin() -> u64;
+        /// Ends the interval opened by `nice_signpost_draw_begin` (0 = no-op).
+        fn nice_signpost_draw_end(id: u64);
+    }
+
+    /// RAII guard for one "Draw" signpost interval; Drop covers all exits.
+    /// Also times the draw (spike 6): the guard's lifetime IS the CPU-side
+    /// draw-submission interval, so Drop records `t0.elapsed()` into
+    /// `nice_poc_metrics::DRAW_DUR_NS` — recorded ALWAYS (independent of
+    /// whether a signpost recorder is attached; a Vec push per draw).
+    pub(super) struct DrawSignpost {
+        id: u64,
+        t0: std::time::Instant,
+    }
+
+    impl DrawSignpost {
+        #[inline]
+        pub(super) fn begin() -> Self {
+            DrawSignpost {
+                id: unsafe { nice_signpost_draw_begin() },
+                t0: std::time::Instant::now(),
+            }
+        }
+    }
+
+    impl Drop for DrawSignpost {
+        #[inline]
+        fn drop(&mut self) {
+            crate::nice_poc_metrics::record_draw_dur_ns(self.t0.elapsed().as_nanos() as u64);
+            unsafe { nice_signpost_draw_end(self.id) }
+        }
+    }
 }
diff --color=never -ruN a/src/platform/mac/nice_signpost.c b/src/platform/mac/nice_signpost.c
--- a/src/platform/mac/nice_signpost.c	1969-12-31 16:00:00
+++ b/src/platform/mac/nice_signpost.c	2026-07-02 00:42:07
@@ -0,0 +1,72 @@
+// NICE PHASE-0 PATCH — os_signpost "Draw" interval shim.
+//
+// Why C and not Rust FFI: the os_signpost macros place the name/format
+// strings in the special __TEXT sections the signpost runtime expects and
+// pass the correct dso handle, so intervals are guaranteed visible to
+// `xctrace record --template Logging`. Hand-rolled Rust calls into
+// `_os_signpost_emit_with_name_impl` can silently emit nothing if either
+// detail is off — this spike cannot afford a silent failure discovered only
+// at live-run time.
+//
+// Contract (the keystroke-latency injection/reduction harness keys on these
+// exact strings — keep in sync with spikes/phase0-poc/README.md):
+//   subsystem: "dev.nickanderssohn.gpui-term"
+//   category : "present"
+//   name     : "Draw"
+//
+// Semantics: one interval per MetalRenderer::draw — CPU-side draw submission
+// (drawable acquire -> encode -> commandBuffer commit [-> waitUntilScheduled
+// -> drawable.present() in transactional mode]). NOT GPU-complete. Symmetric
+// to SwiftTerm's "Metal.Draw" (subsystem org.tirania.SwiftTerm, category
+// MetalProfile), which spans its draw(in:) the same way.
+//
+// Zero overhead when no recorder is attached: os_signpost_enabled() gates
+// begin; a 0 id makes end a no-op.
+
+#include <dispatch/dispatch.h>
+#include <os/log.h>
+#include <os/signpost.h>
+#include <stdatomic.h>
+#include <stdint.h>
+
+// Process-wide count of MetalRenderer::draw invocations (= actual Metal
+// draw/present submissions), counted regardless of whether a signpost
+// recorder is attached. The interactive keystroke-latency mode reports this
+// so its summary counts REAL renderer draws, not just GPUI scene rebuilds
+// (which happen on cx.notify() even when nothing is ever presented).
+static _Atomic uint64_t nice_draw_count;
+
+uint64_t nice_signpost_draw_count(void) {
+    return atomic_load_explicit(&nice_draw_count, memory_order_relaxed);
+}
+
+static os_log_t nice_poc_log(void) {
+    static os_log_t log;
+    static dispatch_once_t once;
+    dispatch_once(&once, ^{
+        log = os_log_create("dev.nickanderssohn.gpui-term", "present");
+    });
+    return log;
+}
+
+uint64_t nice_signpost_draw_begin(void) {
+    atomic_fetch_add_explicit(&nice_draw_count, 1, memory_order_relaxed);
+    os_log_t log = nice_poc_log();
+    if (!os_signpost_enabled(log)) {
+        return (uint64_t)OS_SIGNPOST_ID_NULL;
+    }
+    os_signpost_id_t spid = os_signpost_id_generate(log);
+    if (spid == OS_SIGNPOST_ID_NULL || spid == OS_SIGNPOST_ID_INVALID) {
+        return (uint64_t)OS_SIGNPOST_ID_NULL;
+    }
+    os_signpost_interval_begin(log, spid, "Draw");
+    return (uint64_t)spid;
+}
+
+void nice_signpost_draw_end(uint64_t spid) {
+    if (spid == (uint64_t)OS_SIGNPOST_ID_NULL ||
+        spid == (uint64_t)OS_SIGNPOST_ID_INVALID) {
+        return;
+    }
+    os_signpost_interval_end(nice_poc_log(), (os_signpost_id_t)spid, "Draw");
+}
