+    /// Hand the in-flight left-mouse press to the window server as a window-
+    /// move drag — `performWindowDragWithEvent:` is the same mechanism the
+    /// native title bar uses, so snapping / space-switching / release behave
+    /// identically to a title-bar drag. Must be called from inside GPUI's
+    /// mouse-down dispatch: gpui's `handle_view_event` runs the app callback
+    /// synchronously inside the view's `mouseDown:`, so the NSWindow's
+    /// `currentEvent` IS the pressing mouse-down NSEvent.
+    fn start_window_drag(window: &Window) {
+        let Ok(handle) = HasWindowHandle::window_handle(window) else {
+            return;
+        };
+        let RawWindowHandle::AppKit(appkit) = handle.as_raw() else {
+            return;
+        };
+        let ns_view = appkit.ns_view.as_ptr() as *mut NSView;
+        if ns_view.is_null() {
+            return;
+        }
+        unsafe {
+            let view: &NSView = &*ns_view;
+            let Some(ns_window) = view.window() else {
+                return;
+            };
+            let Some(event) = ns_window.currentEvent() else {
+                return;
+            };
+            ns_window.performWindowDragWithEvent(&event);
+        }
+    }
