# Generated from xcodegen / Info.plist
# (regenerate via `xcodegen generate`)
Nice.xcodeproj/
Resources/Info.generated.plist

# Release signing credentials (sourced by scripts/release.sh for local runs)
scripts/.env.release

# Crash-recovery backup written by scripts/test.sh and scripts/install.sh
# while project.yml is being patched. Cleaned up on clean exit; if it
# survives a run, the next script invocation uses it to restore.
.scripts-project-yml.bak

# Runtime lock file written by Claude Code's `/loop` scheduler. Lives
# per-worktree so it doesn't conflict with parallel loops elsewhere;
# never meant to be committed.
.claude/scheduled_tasks.lock

# Rust rewrite (Path B)
# Vendored pinned zed/GPUI checkout (~1 GB) — reproduced by
# scripts/vendor-zed.sh from patches/zed-bg-luminance.patch, never committed.
/vendor/
# Cargo build output.
/target/
# scripts/rust-bundle.sh output (the assembled "Nice RS Dev.app" bundle,
# staged before scripts/rust-install.sh copies it to /Applications).
/build-rs/

# macOS
.DS_Store
